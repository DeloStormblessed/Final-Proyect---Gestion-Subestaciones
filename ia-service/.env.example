# Mismo secreto y algoritmo que el backend Node — NO cambiar el algoritmo
JWT_SECRET="cambia-esto-en-produccion-con-un-valor-aleatorio-largo"
JWT_ALGORITHM="HS256"

# URL base del backend Node (sin barra final)
NODE_API_URL="http://localhost:3000/api/v1"

# Mismo Postgres que Node — Python gestiona sus propias tablas (historial de chat)
DATABASE_URL="postgresql://gmao:gmao_dev_password@localhost:5432/gestion_subestaciones"

# API key de Groq (gratuita en console.groq.com)
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# Origen permitido para CORS. Vacío en desarrollo (acepta cualquier origen).
ALLOWED_ORIGIN=""
